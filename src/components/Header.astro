---
const nav = [
  { label: 'Articles', href: '/articles' },
  { label: 'ABLE accounts', href: '/able-accounts' },
  { label: 'Benefits', href: '/benefits' },
  { label: 'About', href: '/about' },
];
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="wordmark" aria-label="One Less Thing — home">
      <span class="wm-plain">One </span><span class="wm-teal">Less</span><span class="wm-plain"> Thing</span><span class="wm-dot" aria-hidden="true"></span>
    </a>

    <nav aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {nav.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class={`nav-link${currentPath.startsWith(href) ? ' nav-link--active' : ''}`}
              aria-current={currentPath.startsWith(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/newsletter" class="btn btn--primary header-cta">Get the newsletter</a>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 60px;
  }
  .wordmark {
    display: flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    flex-shrink: 0;
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .wm-plain { color: var(--color-navy); }
  .wm-teal  { color: var(--color-teal); }
  .wm-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
    margin-left: 3px;
    margin-bottom: 1px;
    flex-shrink: 0;
  }
  .nav-list {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    flex: 1;
  }
  .nav-link {
    display: block;
    padding: 6px 10px;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-body);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.1s, color 0.1s;
  }
  .nav-link:hover { background: var(--color-page-bg); color: var(--color-navy); }
  .nav-link--active { color: var(--color-teal-action); font-weight: 500; }
  .header-cta { margin-left: auto; flex-shrink: 0; }

  @media (max-width: 768px) {
    .nav-list { display: none; }
    .header-cta { font-size: 0.8125rem; padding: 8px 14px; }
  }
</style>
