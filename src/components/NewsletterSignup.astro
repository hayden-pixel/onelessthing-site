---
interface Props {
  heading?: string;
  subhead?: string;
}
const {
  heading = 'Get clarity in your inbox',
  subhead = 'A weekly newsletter on disability benefits, ABLE accounts, and financial planning — plain language, no jargon.',
} = Astro.props;
---

<aside class="newsletter-block" aria-label="Newsletter signup">
  <div class="newsletter-inner">
    <h2 class="newsletter-heading">{heading}</h2>
    <p class="newsletter-sub">{subhead}</p>
    <!-- Replace the src below with your Beehiiv embed URL -->
    <iframe
      src="https://embeds.beehiiv.com/REPLACE_WITH_YOUR_BEEHIIV_EMBED_ID"
      data-test-id="beehiiv-embed"
      width="100%"
      height="52"
      frameborder="0"
      scrolling="no"
      style="border-radius:4px;overflow:hidden;margin-top:1rem;"
      title="Newsletter signup form"
    ></iframe>
    <p class="newsletter-note">Free. Unsubscribe anytime. No spam.</p>
  </div>
</aside>

<style>
  .newsletter-block {
    background: var(--color-teal-bg);
    border: 1px solid var(--color-teal-wash);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin: 2rem 0;
  }
  .newsletter-heading {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
  }
  .newsletter-sub {
    font-size: 0.9375rem;
    color: var(--color-body);
    line-height: 1.6;
    margin-bottom: 0;
  }
  .newsletter-note {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-top: 0.75rem;
  }
</style>
