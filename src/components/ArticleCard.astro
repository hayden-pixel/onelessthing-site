---
import PillarTag from './PillarTag.astro';

interface Props {
  title: string;
  summary: string;
  pillar: string;
  tier: string;
  slug: string;
  lastUpdated: string;
  state?: string;
}

const { title, summary, pillar, tier, slug, lastUpdated, state } = Astro.props;
const tierLabel = tier === 'tier-2' && state ? `${state}` : tier === 'tier-2' ? 'State guide' : null;
---

<article class="article-card">
  <div class="card-tags">
    <PillarTag pillar={pillar} />
    {tierLabel && <span class="state-badge">{tierLabel}</span>}
  </div>
  <h2 class="card-title">
    <a href={`/articles/${slug}`}>{title}</a>
  </h2>
  <p class="card-summary">{summary}</p>
  <p class="card-meta">Updated {lastUpdated}</p>
</article>

<style>
  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .article-card:hover {
    border-color: var(--color-teal-wash);
    box-shadow: 0 2px 12px rgba(13,148,136,.08);
  }
  .card-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .state-badge {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 4px;
    background: var(--color-page-bg);
    color: var(--color-muted);
  }
  .card-title {
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    color: var(--color-navy);
  }
  .card-title a {
    color: inherit;
    text-decoration: none;
  }
  .card-title a:hover { color: var(--color-teal-action); }
  .card-summary {
    font-size: 0.9rem;
    color: var(--color-body);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .card-meta { font-size: 0.8125rem; color: var(--color-muted); margin: 0; }
</style>
