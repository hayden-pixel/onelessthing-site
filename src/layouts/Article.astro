---
import Base from './Base.astro';
import PillarTag from '../components/PillarTag.astro';
import Disclaimer from '../components/Disclaimer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

interface Props {
  title: string;
  summary: string;
  pillar: string;
  tier: string;
  state?: string;
  lastUpdated: string;
  reviewerName?: string;
  reviewerCredential?: string;
  reviewerDate?: string;
}

const {
  title, summary, pillar, tier, state,
  lastUpdated, reviewerName, reviewerCredential, reviewerDate,
} = Astro.props;

const tierLabel = tier === 'tier-1' ? 'Universal guide' : `State guide${state ? ` · ${state}` : ''}`;
---

<Base title={`${title} | One Less Thing`} description={summary}>
  <article>
    <div class="article-header">
      <div class="container--narrow">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/articles">All articles</a>
          <span aria-hidden="true">›</span>
          <PillarTag pillar={pillar} />
        </nav>
        <h1>{title}</h1>
        <p class="lead">{summary}</p>
        <div class="article-meta">
          <span class="tier-badge">{tierLabel}</span>
          <span class="meta-sep" aria-hidden="true">·</span>
          <span class="text-muted">Updated {lastUpdated}</span>
          {reviewerName && (
            <>
              <span class="meta-sep" aria-hidden="true">·</span>
              <span class="text-muted">
                Reviewed by {reviewerName}{reviewerCredential ? `, ${reviewerCredential}` : ''}
                {reviewerDate ? ` (${reviewerDate})` : ''}
              </span>
            </>
          )}
        </div>
      </div>
    </div>

    <div class="article-body container--narrow">
      <div class="prose">
        <slot />
      </div>
    </div>

    <div class="container--narrow">
      <Disclaimer />
      <NewsletterSignup />
    </div>
  </article>
</Base>

<style>
  .article-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 2.5rem 0 2rem;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }
  .breadcrumb a { color: var(--color-teal-action); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .article-header h1 { margin-bottom: 1rem; }
  .lead {
    font-size: 1.125rem;
    color: var(--color-body);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 0.8125rem;
  }
  .tier-badge {
    background: var(--color-teal-wash);
    color: var(--color-teal-action);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
  }
  .meta-sep { color: var(--color-border); }
  .article-body {
    padding: 2.5rem 1.5rem;
  }
  @media (max-width: 640px) {
    .article-header { padding: 1.5rem 0; }
    .article-body { padding: 1.5rem 1rem; }
  }
</style>
